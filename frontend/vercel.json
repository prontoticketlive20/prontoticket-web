{
  "routes": [
    {
      "src": "/evento/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(googlebot|google-inspectiontool|bingbot)"
        }
      ],
      "dest": "https://prontoticket-api-production.up.railway.app/api/events/seo/$1"
    },
    {
      "src": "/sitemap.xml",
      "dest": "https://prontoticket-api-production.up.railway.app/api/events/sitemap"
    }
  ]
}