{
  "redirects": [
    {
      "source": "/sitemap.xml",
      "destination": "https://prontoticket-api-production.up.railway.app/api/events/sitemap",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/evento/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot)"
        }
      ],
      "dest": "https://prontoticket-api-production.up.railway.app/api/events/seo/$1"
    }
  ]
}